{
    "name": "jeffersongoncalves/filament-erp-quality",
    "description": "Filament v5 panel resources for the Laravel ERP quality module — inspections, goals, procedures and non-conformances.",
    "keywords": [
        "laravel",
        "filament",
        "filament-plugin",
        "erp",
        "quality",
        "inspection",
        "non-conformance",
        "goal"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Jefferson Gonçalves",
            "email": "gerson.simao.92@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0",
        "jeffersongoncalves/filament-erp-core": "self.version",
        "jeffersongoncalves/laravel-erp-quality": "dev-main",
        "spatie/laravel-package-tools": "^1.14.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.21",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "JeffersonGoncalves\\FilamentErp\\Quality\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JeffersonGoncalves\\FilamentErp\\Quality\\Tests\\": "tests",
            "JeffersonGoncalves\\Erp\\Quality\\Database\\Factories\\": "vendor/jeffersongoncalves/laravel-erp-quality/database/factories",
            "JeffersonGoncalves\\Erp\\Core\\Database\\Factories\\": "vendor/jeffersongoncalves/laravel-erp-core/database/factories"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "test": "vendor/bin/pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "JeffersonGoncalves\\FilamentErp\\Quality\\FilamentErpQualityServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "homepage": "https://github.com/jeffersongoncalves/filament-erp",
    "support": {
        "issues": "https://github.com/jeffersongoncalves/filament-erp/issues",
        "source": "https://github.com/jeffersongoncalves/filament-erp"
    }
}
